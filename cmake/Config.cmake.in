@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

include("${CMAKE_CURRENT_LIST_DIR}/@ARGS_PACKAGE_NAME@Config.cmake")

if(@SCENARIO_RUNNER_HAS_VGF_RUNTIME@)
    find_dependency(VulkanHeaders CONFIG REQUIRED)
    find_dependency(VGF CONFIG REQUIRED)

    if(TARGET @ARGS_NAMESPACE@::vgf_runtime)
        set_property(TARGET @ARGS_NAMESPACE@::vgf_runtime APPEND PROPERTY
            INTERFACE_LINK_LIBRARIES "Vulkan::Headers;VGF::vgf;VGF::vgf-utils")
    endif()
endif()
