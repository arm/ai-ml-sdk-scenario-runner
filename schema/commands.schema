{
    "$id": "urn:scenario:commands",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "array",
    "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
            "dispatch_graph": {
                "$ref" : "urn:scenario:command:dispatch_graph"
            },
            "dispatch_spirv_graph": {
                "$ref" : "urn:scenario:command:dispatch_spirv_graph"
            },
            "dispatch_compute": {
                "$ref" : "urn:scenario:command:dispatch_compute"
            },
            "dispatch_fragment": {
                "$ref" : "urn:scenario:command:dispatch_fragment"
            },
            "dispatch_barrier": {
                "$ref": "urn:scenario:command:dispatch_barrier"
            },
            "mark_boundary": {
                "$ref" : "urn:scenario:command:mark_boundary"
            },
            "dispatch_optical_flow": {
                "$ref" : "urn:scenario:command:dispatch_optical_flow"
            }
        },
        "oneOf": [
            {
                "required": ["dispatch_graph"]
            },
            {
                "required": ["dispatch_spirv_graph"]
            },
            {
                "required": ["dispatch_compute"]
            },
            {
                "required": ["dispatch_fragment"]
            },
            {
                "required": ["dispatch_barrier"]
            },
            {
                "required": ["mark_boundary"]
            },
            {
                "required": ["dispatch_optical_flow"]
            }
        ]
    }
}
